{
  "name": "uc-intg-onkyo-avr",
  "type": "module",
  "version": "0.9.0",
  "description": "Onkyo/Pioneer/Integra AVR custom integration for Unfolded Circle Remotes",
  "main": "dist/src/index.js",
  "engines": {
    "node": "^22.20 || ^24.12 || >=26"
  },
  "scripts": {
    "format": "prettier --write .",
    "generate-diagram": "npx @mermaid-js/mermaid-cli -i docs/architecture.mmd -o docs/architecture.svg",
    "code-check": "prettier --check . && eslint .",
    "lint": "eslint --fix",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "coverage": "npm run build && vitest run --coverage",
    "start": "npm run build && node dist/src/index.js"
  },
  "dependencies": {
    "@unfoldedcircle/integration-api": "0.5.0",
    "async": "3.2.6",
    "debug": "4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EddyMcNut/uc-intg-onkyo-avr"
  },
  "keywords": [
    "Unfolded",
    "Circle",
    "Remote",
    "Onkyo",
    "Pioneer",
    "Integra"
  ],
  "author": "Ed Nootebos",
  "license": "GNU GPL-v3",
  "bugs": {
    "url": "https://github.com/EddyMcNut/uc-intg-onkyo-avr/issues"
  },
  "homepage": "https://github.com/EddyMcNut/uc-intg-onkyo-avr",
  "overrides": {
    "js-yaml": "3.14.2"
  },
  "devDependencies": {
    "@types/async": "^3.2.25",
    "@types/debug": "^4.1.13",
    "@types/node": "26.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "3.8.4",
    "ts-node": "10.9.2",
    "typescript": "6.0.x",
    "vitest": "4.1.9"
  },
  "allowScripts": {
    "core-js@2.6.12": true,
    "fsevents@1.2.13": true
  }
}
