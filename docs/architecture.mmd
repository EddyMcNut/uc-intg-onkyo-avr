graph TB
    subgraph UC["Unfolded Circle Remote"]
        UCAPI["IntegrationAPI\n(UC SDK)"]
    end

    subgraph Driver["OnkyoDriver  ·  src/driver.ts"]
        direction TB
        SetupH["SetupHandler\nsrc/setupHandler.ts"]
        CC["ConnectCoordinator\nsrc/connectCoordinator.ts"]
        ER["EntityRegistrar\nsrc/entityRegistrar.ts"]
        SEH["SelectEntityHandler\nsrc/selectEntityHandler.ts"]
        SubH["SubscriptionHandler\nsrc/subscriptionHandler.ts"]
    end

    subgraph MediaBrowse["Media-Browser Subsystem"]
        MB["mediaBrowser.ts\nbrowse entrypoint"]
        MBSVC["mediaBrowserServices.ts\nservice delegation facade"]
        BSC["browseServiceContract.ts\nservice IDs + source commands"]
        PMCH["PlayMediaCommandHandler\nsrc/playMediaCommandHandler.ts"]
        MBASE["menuBrowseHandlerBase.ts\nshared menu harvest base"]
        MBSTATE["menuBrowseState.ts\nmenu options + freeze state"]
        MEP["menuEntryParser.ts\nNLS/NLA parsing helpers"]
        THUMB["serviceThumbnails.ts\nlogo/backdrop generation"]
        TIN["TuneIn modules\ntuneInMediaBrowser.ts\ntuneInBrowseHandler.ts\ntuneInBrowserStore.ts\ntuneInMenuStore.ts\ntuneInPreloader.ts"]
        TID["Tidal modules\ntidalMediaBrowser.ts\ntidalBrowseHandler.ts\ntidalBrowserStore.ts"]
        DEE["Deezer modules\ndeezerMediaBrowser.ts\ndeezerBrowseHandler.ts\ndeezerBrowserStore.ts"]
    end

    subgraph ConnLayer["Connection Layer"]
        CM["ConnectionManager\nsrc/connectionManager.ts"]
        RM["ReconnectionManager\nsrc/reconnectionManager.ts"]
        INSTANCES["avrInstances\nMap&lt;string, AvrInstance&gt;\n(plain Map, owned by OnkyoDriver)"]
    end

    subgraph PerAVR["Per Physical AVR  (one set per unique IP)"]
        EISCP["EiscpDriver\nsrc/eiscp.ts\nTCP socket · send queue\nreceive queue"]
        PKT["eiscp-packet.ts\npacket encode / decode"]
        PARSER["IscpCommandParser\neiscp-command-parser.ts\nISCP → CommandResult"]
        MZONE["eiscp-multi-zone.ts\nmulti-zone command builders"]
        ZM["zoneMappings.ts\nzone prefix mappings"]
        CR["CommandReceiver\nsrc/commandReceiver.ts\nISCP → UC attributes"]
        AFC["audioFormatClassifier.ts\naud.io format detection"]
        ZAUP["ZoneAgnosticUpdateProcessor\nsrc/zoneAgnosticUpdateProcessor.ts\nFLD / NLT / metadata fanout"]
        ZAFPR["ZoneAgnosticFrontPanelRouter\nsrc/zoneAgnosticFrontPanelRouter.ts"]
        ZASCR["ZoneAgnosticServiceCommandRouter\nsrc/zoneAgnosticServiceCommandRouter.ts"]
        ZASAD["ZoneAgnosticServiceAdapters\nsrc/zoneAgnosticServiceAdapters.ts\nTuneIn / Tidal / Deezer"]
        ZAMSS["ZoneAgnosticMediaStateStore\nsrc/zoneAgnosticMediaState.ts\nnow-playing · image cache"]
        ZMR["ZoneMediaRenderer\nsrc/zoneMediaRenderer.ts\nalbum-art fetch + push"]
    end

    subgraph PerZone["Per Zone  (main / zone2 / zone3)"]
        CS["CommandSender\nsrc/commandSender.ts\nUC command → eISCP"]
    end

    subgraph State["State & Config"]
        ASM["AvrStateManager\nsrc/avrState.ts\nper-zone state cache"]
        ASQ["AvrStateQueryService\nsrc/avrStateQuery.ts\ndebounced query send"]
        CFG["ConfigManager\nsrc/configManager.ts\nconfig.json"]
        MAPS["Command maps\neiscp-commands.ts\neiscp-mappings.ts"]
        SC["simpleCommands.ts\nSimpleCommandDef →\ngenerated map"]
        CONST["constants.ts\ntiming constants"]
    end

    subgraph AVR["Physical AVR(s)"]
        AVRBox["Onkyo / Pioneer / Integra AVR\nTCP port 60128"]
    end

    %% UC ↔ Driver
    UCAPI -- "Connect / Standby events\nentity commands" --> Driver
    Driver -- "entity attribute updates\ndevice state" --> UCAPI

    %% Driver internals
    UCAPI --> SetupH
    UCAPI --> CC
    CC --> CM
    CC -- "ensureZoneInstances()" --> INSTANCES
    Driver -- "queryAvrState /\nqueryAllZonesState" --> ASQ
    Driver --> MB

    %% Connection layer
    CM --> EISCP
    CM --> CR
    CM --> RM
    INSTANCES --> CS

    %% Browse subsystem wiring
    MB --> MBSVC
    MB --> BSC
    CS --> PMCH
    PMCH --> BSC
    PMCH --> MBSVC
    MBSVC --> TIN
    MBSVC --> TID
    MBSVC --> DEE
    TIN --> MBASE
    TID --> MBASE
    DEE --> MBASE
    TIN --> MBSTATE
    TID --> MBSTATE
    DEE --> MBSTATE
    TIN --> MEP
    TID --> MEP
    DEE --> MEP
    TIN --> THUMB
    TID --> THUMB
    DEE --> THUMB

    %% EiscpDriver sub-modules
    EISCP --> PKT
    EISCP --> PARSER
    EISCP --> MZONE
    EISCP --> ZM

    %% Per-AVR: receive path
    EISCP -- "raw 'data' events" --> CR
    CR --> AFC
    CR -- "zone-agnostic commands" --> ZAUP
    CR -- "write state" --> ASM
    ZAUP -- "read: resolve zones\nwrite: setSource (DAB)" --> ASM
    ZAUP --> ZAFPR
    ZAUP --> ZASCR
    ZASCR --> ZASAD
    ZAUP --> ZAMSS
    ZAUP --> ZMR
    ZAFPR --> ZASAD

    %% EiscpDriver reads state for FM/NET routing
    EISCP -- "read: source / sub-source\nfor FLD routing" --> ASM

    %% Per-zone: send path
    CS --> EISCP
    CS --> ZM

    %% Simple commands: EntityRegistrar passes ALL_SIMPLE_COMMANDS in options; CommandSender looks up cmdId
    ER --> SC
    CS --> SC

    %% SubscriptionHandler queries AVR on subscribe
    SubH --> ASQ

    %% State & Config
    CFG --> Driver
    MAPS --> CR
    MAPS --> CS

    %% AVR TCP
    EISCP <-- "eISCP TCP" --> AVRBox

